// ============================================================
// IT Manager — Database Schema (Prisma)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  admin
  technician
  viewer
}

enum BranchName {
  CEDROS
  CRISTALES
  CDA
  QUIRAMA
}

enum DeviceCategory {
  computer
  laptop
  printer
  camera
  payment_terminal
  server
  network
  phone
  tablet
  scanner
  ups
  other
}

enum DeviceStatus {
  active
  inactive
  maintenance
  retired
  damaged
}

enum MaintenanceType {
  preventive
  corrective
  upgrade
  inspection
}

enum MaintenanceStatus {
  scheduled
  in_progress
  completed
  cancelled
}

enum Priority {
  low
  medium
  high
  critical
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed
}

enum TicketPriority {
  low
  medium
  high
  critical
}

// ============================================================
// MODELS
// ============================================================

model Branch {
  id   String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name BranchName @unique
  slug String     @unique @db.VarChar(50)

  devices Device[]
  users   User[]

  @@map("branches")
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String    @unique @db.VarChar(255)
  password_hash String    @db.VarChar(255)
  name          String    @db.VarChar(255)
  role          UserRole  @default(viewer)
  branch_id     String?   @db.Uuid
  department    String?   @db.VarChar(255)
  avatar_url    String?   @db.Text
  is_active     Boolean   @default(true)
  last_login    DateTime? @db.Timestamptz
  created_at    DateTime  @default(now()) @db.Timestamptz
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamptz

  branch              Branch?             @relation(fields: [branch_id], references: [id])
  devices_created     Device[]            @relation("DevicesCreatedBy")
  maintenance_created MaintenanceRecord[] @relation("MaintenanceCreatedBy")
  maintenance_tech    MaintenanceRecord[] @relation("Technician")
  audit_logs          AuditLog[]
  support_tickets     SupportTicket[]
  notifications       Notification[]

  @@index([branch_id])
  @@map("users")
}

model Device {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String         @db.VarChar(255)
  category          DeviceCategory
  brand             String         @db.VarChar(255)
  model             String         @db.VarChar(255)
  serial_number     String         @unique @db.VarChar(255)
  asset_tag         String?        @db.VarChar(100)
  status            DeviceStatus   @default(active)
  branch_id         String?        @db.Uuid
  location          String         @db.VarChar(255)
  department        String         @db.VarChar(255)
  assigned_to       String?        @db.VarChar(255)
  purchase_date     DateTime?      @db.Date
  warranty_expiry   DateTime?      @db.Date
  ip_address        String?        @db.VarChar(45)
  mac_address       String?        @db.VarChar(17)
  os                String?        @db.VarChar(255)
  os_version        String?        @db.VarChar(100)
  processor         String?        @db.VarChar(255)
  ram_gb            Int?
  storage_gb        Int?
  antivirus         String?        @db.VarChar(255)
  antivirus_updated DateTime?      @db.Date
  antivirus_expiry  DateTime?      @db.Date
  malware_detected  Boolean        @default(false)
  last_antivirus_scan DateTime?    @db.Date
  windows_license_type String?     @db.VarChar(20)
  windows_version      String?     @db.VarChar(100)
  office_license_type  String?     @db.VarChar(20)
  office_version      String?      @db.VarChar(100)
  has_pirated_software Boolean      @default(false)
  hardware_problems String?        @db.Text
  software_problems String?        @db.Text
  changed_parts     String?        @db.Text
  credentials       String?        @db.Text
  last_maintenance  DateTime?      @db.Date
  next_maintenance  DateTime?      @db.Date
  notes             String?        @db.Text
  specs             Json           @default("{}")
  created_at        DateTime       @default(now()) @db.Timestamptz
  updated_at        DateTime       @default(now()) @updatedAt @db.Timestamptz
  created_by        String?        @db.Uuid

  branch              Branch?              @relation(fields: [branch_id], references: [id])
  created_by_user     User?                @relation("DevicesCreatedBy", fields: [created_by], references: [id])
  maintenance_records MaintenanceRecord[]

  @@index([category])
  @@index([status])
  @@index([branch_id])
  @@index([department])
  @@map("devices")
}

model MaintenanceRecord {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  device_id       String           @db.Uuid
  type            MaintenanceType
  status          MaintenanceStatus @default(scheduled)
  priority        Priority         @default(medium)
  title           String           @db.VarChar(255)
  description     String           @db.Text
  scheduled_date  DateTime?        @db.Timestamptz
  completed_date  DateTime?        @db.Timestamptz
  technician_id   String?          @db.Uuid
  cost            Decimal?         @db.Decimal(10, 2)
  parts_used      String?          @db.Text
  findings        String?          @db.Text
  next_maintenance DateTime?       @db.Date
  created_at      DateTime         @default(now()) @db.Timestamptz
  updated_at      DateTime         @default(now()) @updatedAt @db.Timestamptz
  created_by      String?          @db.Uuid

  device          Device  @relation(fields: [device_id], references: [id], onDelete: Cascade)
  technician      User?   @relation("Technician", fields: [technician_id], references: [id])
  created_by_user User?   @relation("MaintenanceCreatedBy", fields: [created_by], references: [id])

  @@index([device_id])
  @@index([status])
  @@map("maintenance_records")
}

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String?  @db.Uuid
  action      String   @db.VarChar(255)
  entity_type String?  @db.VarChar(100)
  entity_id   String?  @db.Uuid
  details     Json?
  ip_address  String?  @db.VarChar(45)
  created_at  DateTime @default(now()) @db.Timestamptz

  user User? @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("audit_log")
}

model SupportTicket {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employee_name  String         @db.VarChar(255)
  employee_email String?        @db.VarChar(255)
  is_blocking    Boolean        @default(false)
  branch_name    String         @db.VarChar(100)
  department     String         @db.VarChar(255)
  category       String         @db.VarChar(100)
  subject        String         @db.VarChar(255)
  description    String         @db.Text
  ip_address     String?        @db.VarChar(45)
  status         TicketStatus   @default(open)
  priority       TicketPriority @default(medium)
  assigned_to    String?        @db.Uuid
  created_at     DateTime       @default(now()) @db.Timestamptz
  updated_at     DateTime       @default(now()) @updatedAt @db.Timestamptz

  assigned_user  User?          @relation(fields: [assigned_to], references: [id])

  @@index([status])
  @@index([created_at])
  @@map("support_tickets")
}

model Notification {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  type       String    @db.VarChar(50)
  title      String    @db.VarChar(255)
  message    String    @db.Text
  link       String?   @db.VarChar(500)
  read_at    DateTime? @db.Timestamptz
  created_at DateTime  @default(now()) @db.Timestamptz

  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, read_at])
  @@index([created_at])
  @@map("notifications")
}

// ============================================================
// RATE LIMITING — DB-backed for multi-instance/serverless
// ============================================================

model RateLimit {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key       String   @db.VarChar(255)
  count     Int      @default(1)
  expiresAt DateTime @db.Timestamptz
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@unique([key])
  @@index([expiresAt])
  @@map("rate_limits")
}
