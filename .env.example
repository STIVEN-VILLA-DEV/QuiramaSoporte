# ── Database (NeonDB / PostgreSQL) ────────────────────────────
DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/neondb?sslmode=require"

# ── JWT Secret (REQUIRED — min 32 chars) ──────────────────────
# La app NO arranca si falta o es inseguro.
# Generalo con: openssl rand -base64 48
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-long"

# ── Resend (para notificaciones por email) ─────────────────────
# Creá una API key gratis en https://resend.com → API Keys
# En desarrollo usá el sender onboarding@resend.dev (limitado)
# En produccion agregá y verificá tu dominio
RESEND_API_KEY="re_xxxxx"
RESEND_FROM="onboarding@resend.dev"

# ── App URL (para enlaces en correos) ──────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Environment ───────────────────────────────────────────────
NODE_ENV="development"
